# PostgreSQL
DATABASE_URL=postgresql://ai:aipass@db:5432/thinktank

# JWT 签名密钥（生产环境务必修改）
JWT_SECRET=thinktank-jwt-secret-change-in-production

# Kimi (Moonshot) LLM
LLM_API_KEY=sk-your-moonshot-api-key
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_MODEL=moonshot-v1-8k

# Embedding 模型缓存路径（容器内）
EMBEDDING_MODEL_PATH=/models

# 分片配置
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# 检索配置
TOP_K=5
SIMILARITY_THRESHOLD=0.7

# 上传目录
UPLOAD_DIR=/app/uploads
